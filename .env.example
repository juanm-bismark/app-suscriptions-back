# Secrets — DO NOT commit real values. Copy this file to .env and fill in.
# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Used by local FastAPI/uvicorn processes on the host machine.
DATABASE_URL=postgresql+asyncpg://app_user:CHANGE_ME_DB_PASSWORD@localhost:5432/app_suscripciones
# Used by docker-compose.yml inside the API container.
DATABASE_URL_DOCKER=postgresql+asyncpg://app_user:CHANGE_ME_DB_PASSWORD@db:5432/app_suscripciones
# Used by the Postgres container.
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=app_suscripciones

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_secret
JWT_EXPIRE_MINUTES=60
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_to_a_fernet_key

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Feature flags
# When `LIFECYCLE_WRITES_ENABLED` is `true`, lifecycle write operations
# (set status, purge/retire, network reset) will be allowed. Default: false.
LIFECYCLE_WRITES_ENABLED=false

# Moabits listing enrichment. API v1 discovers ICCIDs; API v2 enriches the
# returned page with detail/connectivity when available. Failures degrade to v1.
MOABITS_V2_ENRICHMENT_ENABLED=true
MOABITS_V2_BASE_URL=https://apiv2.myorion.co
MOABITS_V2_MAX_BATCH=50
MOABITS_V2_MAX_CONCURRENT_CHUNKS=4
MOABITS_V2_DETAIL_TIMEOUT_SECONDS=10.0
MOABITS_V2_CONNECTIVITY_TIMEOUT_SECONDS=5.0
