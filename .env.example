# Secrets — DO NOT commit real values. Copy this file to .env and fill in.

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xefigwniuxbsbwgxljir.supabase.co

# Dashboard → Project Settings → API → service_role key  (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Direct connection (persistent servers):
DATABASE_URL=postgresql+psycopg://postgres:[DB_PASSWORD]@db.xefigwniuxbsbwgxljir.supabase.co:5432/postgres

# Pooler / transaction mode (serverless / high concurrency):
# DATABASE_URL=postgresql+psycopg://postgres.xefigwniuxbsbwgxljir:[DB_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins. Use ["*"] for development.
CORS_ORIGINS=["http://localhost:3000"]
